# ════════════════════════════════════════════════════════════
#  FITNESS BUDDY — Environment Variables Template
#  ────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your credentials.
#  NEVER commit the actual .env file to version control!
#
#  cp .env.example .env
# ════════════════════════════════════════════════════════════

# ── IBM Watsonx.ai Credentials ────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_APIKEY=your_ibm_cloud_api_key_here

# Obtain from your Watsonx.ai project settings page
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Regional endpoint — choose the one matching your IBM Cloud region:
#   us-south : https://us-south.ml.cloud.ibm.com  (Dallas)
#   eu-de    : https://eu-de.ml.cloud.ibm.com      (Frankfurt)
#   eu-gb    : https://eu-gb.ml.cloud.ibm.com      (London)
#   jp-tok   : https://jp-tok.ml.cloud.ibm.com     (Tokyo)
#   au-syd   : https://au-syd.ml.cloud.ibm.com     (Sydney)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Flask Configuration ───────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-strong-random-secret-key

# Set to "true" for verbose logging during development
FLASK_DEBUG=false

# Port the app listens on (default 5000)
PORT=5000
